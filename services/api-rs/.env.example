API_BIND=127.0.0.1:8080
API_NODE_FINGERPRINT=hexrelay-local-fingerprint
API_DATABASE_URL=postgres://hexrelay:hexrelay_dev_password@127.0.0.1:5432/hexrelay
API_ALLOWED_ORIGINS=http://localhost:3002,http://127.0.0.1:3002
# Preferred keyring format for token signing key rotation.
# Format: key_id:secret,key_id_2:secret_2
API_SESSION_SIGNING_KEYS=v1:hexrelay-dev-signing-key-change-me
API_SESSION_SIGNING_KEY_ID=v1
# Backward-compatible single key fallback if keyring is not set.
API_SESSION_SIGNING_KEY=hexrelay-dev-signing-key-change-me
API_AUTH_CHALLENGE_RATE_LIMIT=30
API_AUTH_VERIFY_RATE_LIMIT=30
API_INVITE_CREATE_RATE_LIMIT=20
API_INVITE_REDEEM_RATE_LIMIT=40
API_RATE_LIMIT_WINDOW_SECONDS=60
RUST_LOG=api_rs=info,tower_http=info
