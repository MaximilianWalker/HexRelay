API_BIND=127.0.0.1:8080
API_ENVIRONMENT=development
# Keep disabled by default until a trusted identity-claim flow exists.
API_ALLOW_PUBLIC_IDENTITY_REGISTRATION=false
# Dev-only local fixture/session endpoints. Must remain false in production.
API_ENABLE_DEV_TESTING=false
API_SERVER_ID=hexrelay-local-server
# Optional bootstrap allowlists for app-mediated server administration.
# Owners imply admin authority; admins can manage server settings without owner scope.
# API_SERVER_OWNER_IDENTITY_IDS=
# API_SERVER_ADMIN_IDENTITY_IDS=
API_DATABASE_URL=postgres://hexrelay:hexrelay_dev_password@127.0.0.1:5432/hexrelay
API_ALLOWED_ORIGINS=http://localhost:3002,http://127.0.0.1:3002
API_TRUST_PROXY_HEADERS=false
API_CHANNEL_DISPATCH_INTERNAL_TOKEN=hexrelay-dev-channel-dispatch-token-change-me
API_PRESENCE_WATCHER_INTERNAL_TOKEN=hexrelay-dev-presence-watcher-token-change-me
API_REALTIME_BASE_URL=http://127.0.0.1:8081
# Optional Redis-backed contact presence snapshot source.
# API_PRESENCE_REDIS_URL=redis://127.0.0.1:6379/0
# Optional static private-mesh peer descriptors. JSON array of signed server descriptors.
# API_STATIC_PEER_DESCRIPTORS_JSON=[]
# Optional signed private-mesh peer invite envelopes. JSON array of issuer descriptor + signed invite.
# API_STATIC_PEER_INVITES_JSON=[]
# Optional CSV of revoked peer invite IDs refused during static peer invite validation.
# API_REVOKED_STATIC_PEER_INVITE_IDS=
API_STATIC_PEER_DESCRIPTOR_MAX_TTL_SECONDS=86400
# Optional local server-to-server signing identity for authenticated server-to-server forwarding.
# API_LOCAL_SERVER_DESCRIPTOR_JSON={"server_id":"hexrelay-local-server",...}
# API_LOCAL_SERVER_PRIVATE_KEY_PKCS8_BASE64=<base64-ed25519-pkcs8>
# Preferred keyring format for token signing key rotation.
# Format: key_id:secret,key_id_2:secret_2
API_SESSION_SIGNING_KEYS=v1:hexrelay-dev-signing-key-change-me
API_SESSION_SIGNING_KEY_ID=v1
# Backward-compatible single key fallback if keyring is not set.
API_SESSION_SIGNING_KEY=hexrelay-dev-signing-key-change-me
# For dedicated/public deployments keep this true.
API_SESSION_COOKIE_SECURE=false
API_SESSION_COOKIE_SAME_SITE=Lax
# Optional for dedicated server deployments sharing a parent domain.
# API_SESSION_COOKIE_DOMAIN=.example.com
API_AUTH_CHALLENGE_RATE_LIMIT=30
API_AUTH_VERIFY_RATE_LIMIT=30
API_DISCOVERY_QUERY_RATE_LIMIT=30
API_INVITE_CREATE_RATE_LIMIT=20
API_INVITE_REDEEM_RATE_LIMIT=40
# Fixed-window seconds used by both in-process fallback and DB-backed distributed limiter.
API_RATE_LIMIT_WINDOW_SECONDS=60
RUST_LOG=api_rs=info,tower_http=info
