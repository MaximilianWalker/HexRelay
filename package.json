{
  "name": "hexrelay-workspace",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": "^24.15.0 || >=25"
  },
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "setup:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup.ps1",
    "seed": "node scripts/seed.mjs",
    "seed:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/seed.ps1",
    "seed:unix": "bash scripts/seed.sh",
    "reset-dev-db": "node scripts/reset-dev-db.mjs",
    "reset-dev-db:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/reset-dev-db.ps1",
    "reset-dev-db:unix": "bash scripts/reset-dev-db.sh",
    "start": "node scripts/run.mjs",
    "run": "npm run start",
    "start:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run.ps1",
    "status": "node scripts/status.mjs",
    "status:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/status.ps1",
    "status:unix": "bash scripts/status.sh",
    "stop": "node scripts/stop.mjs",
    "stop:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop.ps1",
    "stop:unix": "bash scripts/stop.sh",
    "network": "node scripts/network/index.mjs",
    "network:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/network.ps1",
    "network:unix": "bash scripts/network.sh",
    "runtime:docker": "node scripts/runtime/docker.mjs",
    "validate:runtime-profiles": "node scripts/validators/runtime-profiles.mjs",
    "validate:network-profiles": "node scripts/validators/network-profiles.mjs",
    "test": "node tests/run.mjs",
    "test:runtime": "node tests/runtime/runtime-smoke.mjs",
    "test:network": "node tests/runtime/network-smoke.mjs",
    "test:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File tests/run.ps1",
    "test:unix": "bash tests/run.sh",
    "security": "bash scripts/ensure-cargo-audit.sh && cargo audit --deny warnings --ignore RUSTSEC-2023-0071"
  }
}
